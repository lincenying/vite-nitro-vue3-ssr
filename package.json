{
  "name": "vite-nitro-vue3-ssr",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare[-del]": "npx simple-git-hooks",
    "serve": "vite",
    "build": "vite build",
    "preview": "cross-env NODE_ENV=production HOST=127.0.0.1 PORT=5273 node .output/server/index.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ts": "vue-tsc -b --noEmit",
    "lint:css": "stylelint '**/*.{css,scss}' --fix",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@lincy/async-validation": "catalog:prod",
    "@lincy/utils": "catalog:prod",
    "@tato30/vue-pdf": "catalog:prod",
    "@unhead/vue": "catalog:prod",
    "@unocss/reset": "catalog:prod",
    "@vueuse/core": "catalog:prod",
    "@vueuse/router": "catalog:prod",
    "alova": "catalog:prod",
    "better-sqlite3": "catalog:prod",
    "default-passive-events": "catalog:prod",
    "destr": "catalog:prod",
    "element-plus": "catalog:prod",
    "h3": "catalog:prod",
    "highlight.js": "catalog:prod",
    "markdown-it-link-attributes": "catalog:prod",
    "md-editor-v3": "catalog:prod",
    "mitt": "catalog:prod",
    "nitropack": "catalog:prod",
    "ofetch": "catalog:prod",
    "pinia": "catalog:prod",
    "qs": "catalog:prod",
    "store2": "catalog:prod",
    "vue": "catalog:prod",
    "vue-router": "catalog:prod"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-nitro": "catalog:dev",
    "@element-plus/icons-vue": "catalog:dev",
    "@lincy/eslint-config": "catalog:lint",
    "@lincy/stylelint-config": "catalog:lint",
    "@lincy/unocss-base-config": "catalog:dev",
    "@types/markdown-it-link-attributes": "catalog:types",
    "@types/mockjs": "catalog:types",
    "@types/node": "catalog:types",
    "@types/qs": "catalog:types",
    "@vitejs/plugin-vue": "catalog:dev",
    "@vitejs/plugin-vue-jsx": "catalog:dev",
    "@vue-macros/define-props": "catalog:dev",
    "@vue-macros/define-props-refs": "catalog:dev",
    "@vue-macros/reactivity-transform": "catalog:dev",
    "cross-env": "catalog:dev",
    "eslint": "catalog:lint",
    "eslint-plugin-format": "catalog:lint",
    "lint-staged": "catalog:lint",
    "mockjs": "catalog:dev",
    "sass-embedded": "catalog:dev",
    "stylelint": "catalog:lint",
    "typescript": "catalog:dev",
    "unocss": "catalog:dev",
    "unplugin-auto-import": "catalog:dev",
    "unplugin-icons": "catalog:dev",
    "unplugin-vue-components": "catalog:dev",
    "vite": "catalog:dev",
    "vite-plugin-inspect": "catalog:dev",
    "vite-plugin-node-polyfills": "catalog:dev",
    "vite-plugin-progress": "catalog:dev",
    "vue-macros": "catalog:dev",
    "vue-tsc": "catalog:dev"
  },
  "simple-git-hooks[-del]": {
    "pre-commit": "npm run lint-staged"
  },
  "lint-staged[-del]": {
    "*.{[jt]s?(x),vue,md}": "eslint --fix",
    "*.{css,scss}": "stylelint --fix --allow-empty-input"
  }
}
